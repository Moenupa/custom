sl (<QUEUED_JOBIDS> || (<SL_OPTION> | <SL_LOCAL>))...;

<SL_LOCAL> ::=
    (-l | --[no-]local) "Use local or slurm search mode (default: slurm)"
    ;

<SL_OPTION> ::=
    (-h | --help) "Show help message and exit"
    | (-c | --[no-]color,) "Color output (default: true)"
    | (-e | --[no-]stderr,) "Show stdERR (default: true)"
    | (-o | --[no-]stdout,) "Show stdOUT (default: false)"
    ;

<QUEUED_JOBIDS> ::= {{{ squeue -u $USER -ho '%A|%j|%T' | tr -s '|' '\t' }}};
